{
  "name": "eral",
  "version": "1.0.0",
  "description": "ERAL (Execution Reliability & Anticipation Layer) — a probabilistic gating engine that replaces try-catch web automation with local DOM simulation and confidence-scored execution.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "postbuild": "node scripts/postbuild.mjs",
    "postinstall": "npm run build",
    "start": "node dist/src/index.js",
    "demo": "tsx examples/notion-editor-ready.ts",
    "demo:notion": "tsx examples/notion-editor-ready.ts",
    "demo:ghost": "tsx examples/ghost-publish.ts",
    "demo:linkedin": "tsx examples/linkedin-post.ts",
    "demo:live": "npm run build && node dist/examples/playwright-live-demo.js",
    "demo:registry": "tsx examples/registry-learning-demo.ts",
    "demo:simulate": "npm run build && node dist/examples/simulate-interrupt-demo.js",
    "demo:calibration": "tsx examples/calibration-demo.ts",
    "calibrate": "tsx scripts/calibrate.ts"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "dependencies": {
    "typescript": "^5.5.4"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "playwright": "^1.61.1",
    "tsx": "^4.16.2"
  }
}
